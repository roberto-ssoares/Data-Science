
name: cluster-rss-spark

services:
  spark-master-rss:
    container_name: spark-master-rss
    build: .
    image: spark-image-rss
    entrypoint: ['./entrypoint.sh', 'master']
    healthcheck:
      test: [ "CMD", "curl", "-f", "http://localhost:8080" ]
      interval: 5s
      timeout: 3s
      retries: 3
    volumes:
      - ./datasets:/opt/spark/dados
      - ./projetos:/opt/spark/jobs
      - spark-logs:/opt/spark/spark-events
    env_file:
      - .env.spark
    ports:
      - '9090:8080'
      - '7077:7077'

  spark-history-rss:
    container_name: spark-history-rss
    image: spark-image-rss
    entrypoint: ['./entrypoint.sh', 'history']
    depends_on:
      - spark-master-rss
    env_file:
      - .env.spark
    volumes:
      - spark-logs:/opt/spark/spark-events
    ports:
      - '18080:18080'

  spark-worker-rss:
    image: spark-image-rss
    entrypoint: ['./entrypoint.sh', 'worker']
    depends_on:
      - spark-master-rss
    env_file:
      - .env.spark
    volumes:
      - ./datasets:/opt/spark/dados
      - ./projetos:/opt/spark/jobs
      - spark-logs:/opt/spark/spark-events

volumes:
  spark-logs:




